generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Round {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  status           String    // CREATED | STARTED | REVEALED
  nonce            String
  commitHex        String
  serverSeed       String?
  clientSeed       String    @default("")
  combinedSeed     String    @default("")
  pegMapHash       String    @default("")
  rows             Int       @default(12)
  dropColumn       Int       @default(6)
  binIndex         Int       @default(-1)
  payoutMultiplier Float     @default(0)
  betCents         Int       @default(0)
  pathJson         Json      @default("[]")
  pathString       String    @default("")
  revealedAt       DateTime?
}
